generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  language           String   @default("en")
  role               Role     @default(USER)
  subscriptionStatus String   @default("inactive")
  refreshTokenHash   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patients           Patient[]
}

enum Role {
  USER
  ADMIN
}

model Patient {
  id            String   @id @default(uuid())
  userId        String

  fullName      String
  dateOfBirth   DateTime
  gender        String?

  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User @relation(fields:[userId], references:[id], onDelete: Cascade)

  doctors       Doctor[]
  medications   Medication[]
  events        Event[]
  patientNotes  PatientNote[]
  contacts      EmergencyContact[]
}

model Doctor {
  id            String @id @default(uuid())
  patientId     String

  name          String
  specialty     String?
  phone         String?
  email         String?

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model EmergencyContact {
  id            String @id @default(uuid())
  patientId     String

  name          String
  relationship  String
  phone         String

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model Medication {
  id            String @id @default(uuid())
  patientId     String

  name          String
  dosage        String?
  frequency     String?

  purpose       String?
  sideEffects   String?

  createdAt     DateTime @default(now())

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model Event {
  id            String @id @default(uuid())
  patientId     String

  title         String
  description   String?

  eventDate     DateTime

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model PatientNote {
  id            String @id @default(uuid())
  patientId     String

  title         String
  content       String

  createdAt     DateTime @default(now())

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model MedicationReference {
  id          String   @id @default(uuid())

  name        String
  language    String

  purpose     String
  sideEffects String
  warnings    String

  createdAt   DateTime @default(now())

  @@unique([name, language])
}
