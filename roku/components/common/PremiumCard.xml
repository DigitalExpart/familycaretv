<?xml version="1.0" encoding="utf-8" ?>
<component name="PremiumCard" extends="Group">
    <interface>
        <field id="title" type="string" />
        <field id="iconUri" type="string" />
        <field id="targetScene" type="string" />
        <field id="itemSelected" type="boolean" value="false" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/common/PremiumCard.brs" />
    
    <children>
        <Rectangle id="background" 
            width="300" height="200" 
            color="0x2C2C35FF" 
            translation="[0, 0]" />
            
        <Poster id="icon" 
            width="80" height="80" 
            translation="[110, 40]" 
            loadDisplayMode="scaleToFit" />
            
        <Label id="titleLabel" 
            font="font:SmallSystemFont" 
            color="0xFFFFFFFF" 
            horizAlign="center" 
            translation="[0, 140]" 
            width="300" />
            
        <Animation id="focusAnimation" duration="0.2" repeat="false" easeFunction="linear">
            <Vector2DFieldInterpolator id="scaleInterp" 
                key="[0.0, 1.0]" 
                keyValue="[ [1.0, 1.0], [1.05, 1.05] ]" 
                fieldToInterp="background.scale" />
            <ColorFieldInterpolator id="colorInterp" 
                key="[0.0, 1.0]" 
                keyValue="[ 0x2C2C35FF, 0x4B4B6FFF ]" 
                fieldToInterp="background.color" />
        </Animation>
    </children>
</component>
