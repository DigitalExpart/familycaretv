<?xml version="1.0" encoding="utf-8" ?>
<component name="NotificationBanner" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/common/NotificationBanner.brs" />
    <interface>
        <field id="notification" type="assocarray" />
        <function name="showBanner" />
    </interface>
    
    <children>
        <Rectangle id="backgroundRect" width="500" height="120" color="0x333333" itemSpacings="[10,10]">
            <Label id="titleLabel" translation="[20, 20]" width="460" font="font:MediumBoldSystemFont" color="0xFFFFFF" />
            <Label id="messageLabel" translation="[20, 60]" width="460" wrap="true" font="font:SmallSystemFont" color="0xCCCCCC" />
            <Rectangle id="priorityBar" width="10" height="120" translation="[0, 0]" color="0x00FF00" />
        </Rectangle>
        
        <Animation id="slideIn" duration="0.5" easeFunction="linear">
            <Vector2DFieldInterpolator id="slideInInterp" key="[0, 1]" keyValue="[[0, -150], [0, 20]]" fieldToInterp="backgroundRect.translation" />
        </Animation>
        
        <Animation id="slideOut" duration="0.5" easeFunction="linear">
            <Vector2DFieldInterpolator id="slideOutInterp" key="[0, 1]" keyValue="[[0, 20], [0, -150]]" fieldToInterp="backgroundRect.translation" />
        </Animation>
        
        <Timer id="dismissTimer" duration="5" repeat="false" />
    </children>
</component>
