<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">

    <interface>
        <field id="nextScreen" type="string" onChange="onNextScreenChange" />
    </interface>
    
    <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />

    <children>
        <!-- Background -->
        <Rectangle id="background" width="1920" height="1080" color="0x1A1A1A" />
        
        <!-- Navigation Manager handles screen stack -->
        <NavigationManager id="navigationManager" />
        
        <!-- API Poller (runs in background) -->
        <PollingTask id="pollingTask" />

        <!-- Notification Banner Overlay -->
        <NotificationBanner id="notificationBanner" visible="false" translation="[0, -150]" />
    </children>

</component>
