<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScreen" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/screens/HomeScreen.brs" />
    <children>
        <Rectangle id="bg" width="1920" height="1080" color="0x121212" />
        <SidebarMenu id="sidebar" translation="[0, 0]" />
        
        <Group id="contentArea" translation="[350, 50]">
            <!-- Header -->
            <Label id="welcomeText" translation="[0, 0]" font="font:LargeBoldSystemFont" color="0xFFFFFF" text="Good Morning" />
            <Label id="dateText" translation="[0, 60]" font="font:MediumSystemFont" color="0xAAAAAA" />
            
            <!-- Verse of the Day -->
            <Rectangle id="verseCard" width="1500" height="150" translation="[0, 110]" color="0x222222">
                <Label id="verseText" translation="[30, 20]" width="1440" font="font:MediumSystemFont" color="0xFFFFFF" wrap="true" />
                <Label id="verseRef" translation="[30, 100]" width="1440" font="font:SmallBoldSystemFont" color="0xCCCCCC" />
            </Rectangle>
            
            <!-- Dashboard List for Summary and Featured Book -->
            <RowList id="dashboardList" translation="[0, 280]" itemComponentName="PremiumCard" numRows="4" rowItemSize="[[300, 200]]" itemSize="[320, 260]" rowItemSpacing="[[20, 0]]" showRowLabel="true" rowLabelFont="font:MediumBoldSystemFont" rowLabelColor="0xFFFFFF" />
        </Group>
        
        <ApiTask id="fetchDashboardTask" />
    </children>
</component>
