generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  gender             String?
  avatarUrl          String?
  hasConsentedToPrivacy Boolean @default(false)
  language           String   @default("en")
  role               Role     @default(USER)
  
  // Subscription / Stripe fields
  subscriptionStatus String   @default("trialing")
  stripeCustomerId   String?  @unique
  stripeSubscriptionId String? @unique
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?

  refreshTokenHash   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  referralCode       String?  @unique
  referredById       String?
  referredBy         User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referredUsers      User[]   @relation("UserReferrals")

  patients           Patient[]
  deviceLinks        DeviceLink[]
  notifications      Notification[]
  
  referralsMade      Referral[] @relation("Referrer")
  referralReceived   Referral?  @relation("ReferredUser")

  // Platform Expansion Relations
  tasks              Task[]         @relation("UserTasks")
  journals           DailyJournal[] @relation("UserJournals")
  kids               ChildProfile[] @relation("UserKids")
  pets               Pet[]          @relation("UserPets")
}

enum Role {
  USER
  ADMIN
}

model Patient {
  id            String   @id @default(uuid())
  userId        String

  fullName      String
  dateOfBirth   DateTime
  gender        String?

  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User @relation(fields:[userId], references:[id], onDelete: Cascade)

  doctors       Doctor[]
  medications   Medication[]
  events        Event[]
  patientNotes  PatientNote[]
  contacts      EmergencyContact[]
  drawings      Drawing[]
  tasks         Task[]             @relation("PatientTasks")
}

model Doctor {
  id            String @id @default(uuid())
  patientId     String

  name          String
  specialty     String?
  phone         String?
  email         String?

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model EmergencyContact {
  id            String @id @default(uuid())
  patientId     String

  name          String
  relationship  String
  phone         String

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model Medication {
  id            String @id @default(uuid())
  patientId     String

  name          String
  dosage        String?
  frequency     String?

  purpose       String?
  sideEffects   String?

  daysOfWeek    String[]
  timesOfDay    String[]

  durationWeeks Int?
  expiresAt     DateTime?

  createdAt     DateTime @default(now())

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

enum EventType {
  APPOINTMENT
  MEDICATION
  TASK
}

enum ReminderStatus {
  ACTIVE
  COMPLETED
  MISSED
}

model Event {
  id               String   @id @default(uuid())

  patientId        String

  title            String
  description      String?

  type             EventType

  startDateTime    DateTime

  reminderMinutes  Int?

  status           ReminderStatus @default(ACTIVE)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientNote {
  id            String @id @default(uuid())
  patientId     String

  title         String
  content       String

  createdAt     DateTime @default(now())

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model MedicationReference {
  id          String   @id @default(uuid())

  name        String
  language    String

  purpose     String
  sideEffects String
  warnings    String

  createdAt   DateTime @default(now())

  @@unique([name, language])
}

enum AudioType {
  MUSIC
  MESSAGE
}

model BibleVerse {
  id            String   @id @default(uuid())
  verse         String
  reference     String
  scheduledDate DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  verseDays     VerseDay[]
}

model Drawing {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  patientId   String?  // Optional: link to a specific patient

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
}

model AudioTrack {
  id          String   @id @default(uuid())
  title       String
  audioUrl    String
  type        AudioType
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DeviceLink {
  id         String    @id @default(uuid())
  deviceId   String    @unique
  code       String    @unique
  userId     String?
  deviceType String?
  linkedAt   DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  SYSTEM
  MEDICATION_REMINDER
  APPOINTMENT_REMINDER
  TASK_REMINDER
  TASK
  MEDICATION
  EVENT
  VACCINE
  HOMEWORK
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType @default(SYSTEM)
  title       String
  message     String
  isRead      Boolean          @default(false)
  actionUrl   String?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ReferralStatus {
  PENDING
  REGISTERED
  SUBSCRIBED
  PAID
}

model Referral {
  id                 String         @id @default(uuid())
  referrerId         String
  referredUserId     String         @unique
  status             ReferralStatus @default(PENDING)
  commissionEligible Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  referrer           User           @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser       User           @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
}

// ====================================================
// MODULE 1: DAILY TASKS & WELLNESS
// ====================================================

enum TaskCategory {
  MORNING
  DAYTIME
  EVENING
}

model Task {
  id        String       @id @default(uuid())
  userId    String
  patientId String?
  title     String
  category  TaskCategory
  completed Boolean      @default(false)
  date      DateTime

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)
  patient   Patient?     @relation("PatientTasks", fields: [patientId], references: [id], onDelete: SetNull)
}

model DailyJournal {
  id        String   @id @default(uuid())
  userId    String
  content   String
  date      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserJournals", fields: [userId], references: [id], onDelete: Cascade)
}

// ====================================================
// MODULE 2: VERSE OF THE DAY
// ====================================================

model VerseDay {
  id         String   @id @default(uuid())
  verseId    String
  dayOfMonth Int      @unique

  verse      BibleVerse @relation(fields: [verseId], references: [id], onDelete: Cascade)
}

// ====================================================
// MODULE 3: KIDS MANAGEMENT
// ====================================================

model ChildProfile {
  id          String   @id @default(uuid())
  userId      String

  name        String
  schoolName  String?
  grade       String?
  teacher     String?
  teacherPhone String?
  schoolHours String?
  busNumber   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserKids", fields: [userId], references: [id], onDelete: Cascade)

  tasks       ChildTask[]
  events      ChildCalendarEvent[]
  notes       ChildNote[]
}

model ChildTask {
  id        String   @id @default(uuid())
  childId   String
  title     String
  category  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model ChildCalendarEvent {
  id        String   @id @default(uuid())
  childId   String
  title     String
  date      DateTime
  createdAt DateTime @default(now())

  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model ChildNote {
  id        String   @id @default(uuid())
  childId   String
  content   String
  createdAt DateTime @default(now())

  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
}

// ====================================================
// MODULE 4: COLORING BOOKS
// ====================================================

model ColoringPage {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  language  String   @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ====================================================
// MODULE 5: MUSIC LIBRARY
// ====================================================

model MusicCategory {
  id        String   @id @default(uuid())
  name      String

  tracks    MusicTrack[]
}

model MusicTrack {
  id          String   @id @default(uuid())
  title       String
  language    String   @default("en")
  youtubeUrl  String?
  audioUrl    String?
  description String?
  categoryId  String

  category    MusicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

// ====================================================
// MODULE 6: PETS MANAGEMENT
// ====================================================

model Pet {
  id        String   @id @default(uuid())
  userId    String

  name      String
  breed     String?
  age       Int?
  weight    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserPets", fields: [userId], references: [id], onDelete: Cascade)

  veterinarians Veterinarian[]
  clinics       EmergencyClinic[]
  vaccinations  PetVaccination[]
  medications   PetMedication[]
  notes         PetNote[]
}

model Veterinarian {
  id        String   @id @default(uuid())
  petId     String
  name      String
  phone     String?

  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model EmergencyClinic {
  id        String   @id @default(uuid())
  petId     String
  name      String
  phone     String?

  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model PetVaccination {
  id          String   @id @default(uuid())
  petId       String
  vaccineName String
  dateGiven   DateTime?
  nextDue     DateTime?

  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model PetMedication {
  id        String   @id @default(uuid())
  petId     String
  name      String
  dosage    String?
  frequency String?

  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model PetNote {
  id        String   @id @default(uuid())
  petId     String
  content   String

  createdAt DateTime @default(now())

  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}
