generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  gender             String?
  hasConsentedToPrivacy Boolean @default(false)
  language           String   @default("en")
  role               Role     @default(USER)
  
  // Subscription / Stripe fields
  subscriptionStatus String   @default("trialing")
  stripeCustomerId   String?  @unique
  stripeSubscriptionId String? @unique
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?

  refreshTokenHash   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patients           Patient[]
  deviceLinks        DeviceLink[]
  notifications      Notification[]
}

enum Role {
  USER
  ADMIN
}

model Patient {
  id            String   @id @default(uuid())
  userId        String

  fullName      String
  dateOfBirth   DateTime
  gender        String?

  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User @relation(fields:[userId], references:[id], onDelete: Cascade)

  doctors       Doctor[]
  medications   Medication[]
  events        Event[]
  patientNotes  PatientNote[]
  contacts      EmergencyContact[]
  drawings      Drawing[]
}

model Doctor {
  id            String @id @default(uuid())
  patientId     String

  name          String
  specialty     String?
  phone         String?
  email         String?

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model EmergencyContact {
  id            String @id @default(uuid())
  patientId     String

  name          String
  relationship  String
  phone         String

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model Medication {
  id            String @id @default(uuid())
  patientId     String

  name          String
  dosage        String?
  frequency     String?

  purpose       String?
  sideEffects   String?

  createdAt     DateTime @default(now())

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

enum EventType {
  APPOINTMENT
  MEDICATION
  TASK
}

enum ReminderStatus {
  ACTIVE
  COMPLETED
  MISSED
}

model Event {
  id               String   @id @default(uuid())

  patientId        String

  title            String
  description      String?

  type             EventType

  startDateTime    DateTime

  reminderMinutes  Int?

  status           ReminderStatus @default(ACTIVE)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientNote {
  id            String @id @default(uuid())
  patientId     String

  title         String
  content       String

  createdAt     DateTime @default(now())

  patient Patient @relation(fields:[patientId], references:[id], onDelete: Cascade)
}

model MedicationReference {
  id          String   @id @default(uuid())

  name        String
  language    String

  purpose     String
  sideEffects String
  warnings    String

  createdAt   DateTime @default(now())

  @@unique([name, language])
}

enum AudioType {
  MUSIC
  MESSAGE
}

model BibleVerse {
  id            String   @id @default(uuid())
  verse         String
  reference     String
  scheduledDate DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Drawing {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  patientId   String?  // Optional: link to a specific patient

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
}

model AudioTrack {
  id          String   @id @default(uuid())
  title       String
  audioUrl    String
  type        AudioType
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DeviceLink {
  id         String    @id @default(uuid())
  deviceId   String    @unique
  code       String    @unique
  userId     String?
  deviceType String?
  linkedAt   DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  SYSTEM
  MEDICATION_REMINDER
  APPOINTMENT_REMINDER
  TASK_REMINDER
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType @default(SYSTEM)
  title       String
  message     String
  isRead      Boolean          @default(false)
  actionUrl   String?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}
